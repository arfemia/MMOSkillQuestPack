{
  "$Comment": "MMOSkillQuestPack - Dunewalker Ashkar, the Howling Sands campaign giver (desert arc). Auto-spawns once per world where ANY player first discovers the Howling Sands via the guide_sands QuestGiver definition; Target=auto resolves to giver:guide_sands.",
  "Type": "Generic",
  "Parameters": {
    "NameTranslationKey": {
      "Value": "npcs.MMO_Quest_Sands.name",
      "Description": "Display name for the generic quest-giver NPC"
    }
  },
  "StartState": "Idle",
  "DefaultNPCAttitude": "Ignore",
  "DefaultPlayerAttitude": "Neutral",
  "Appearance": "Outlander_Hunter",
  "MaxHealth": 100,
  "IsMemory": false,
  "DisableDamageGroups": [ "Self" ],
  "CombatConfig": {
    "EntityEffect": "Immunity_Environmental"
  },
  "BusyStates": [ "$Interaction" ],
  "Invulnerable": true,
  "KnockbackScale": 0.0,
  "MotionControllerList": [
    {
      "Type": "Walk",
      "MaxWalkSpeed": 5,
      "Gravity": 10,
      "RunThreshold": 0.3,
      "MaxFallSpeed": 15,
      "MaxRotationSpeed": 360,
      "Acceleration": 10
    }
  ],
  "Instructions": [
    {
      "Instructions": [
        {
          "$Comment": "Idle - no player nearby; stand still.",
          "Sensor": { "Type": "State", "State": "Idle" },
          "Instructions": [
            {
              "$Comment": "Wave at an approaching player, then watch.",
              "ActionsBlocking": true,
              "Sensor": { "Type": "Player", "Range": 8 },
              "Actions": [
                { "Type": "PlayAnimation", "Slot": "Status", "Animation": "Wave" },
                { "Type": "State", "State": "Watching" }
              ]
            },
            { "Sensor": { "Type": "Any" }, "BodyMotion": { "Type": "Nothing" } }
          ]
        },
        {
          "$Comment": "Watching - player nearby; track with head, return to Idle when they leave.",
          "Sensor": { "Type": "State", "State": "Watching" },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": { "Type": "Player", "Range": 12 },
              "HeadMotion": { "Type": "Watch" }
            },
            {
              "Continue": true,
              "Sensor": { "Type": "Any" },
              "Actions": [
                { "Type": "Timeout", "Delay": [ 2, 2 ], "Action": { "Type": "PlayAnimation", "Slot": "Status" } }
              ]
            },
            {
              "Sensor": { "Type": "Not", "Sensor": { "Type": "Player", "Range": 12 } },
              "Actions": [
                { "Type": "PlayAnimation", "Slot": "Status" },
                { "Type": "State", "State": "Idle" }
              ]
            },
            { "Sensor": { "Type": "Any" }, "BodyMotion": { "Type": "Nothing" } }
          ]
        },
        {
          "$Comment": "Interaction - the page is open; look at the player, then return to Watching.",
          "Sensor": { "Type": "State", "State": "$Interaction" },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": { "Type": "Target", "Range": 10 },
              "HeadMotion": { "Type": "Watch" }
            },
            {
              "Sensor": { "Type": "Any" },
              "Actions": [
                {
                  "Type": "Timeout",
                  "Delay": [ 1, 1 ],
                  "Action": {
                    "Type": "Sequence",
                    "Actions": [
                      { "Type": "ReleaseTarget" },
                      { "Type": "State", "State": "Watching" }
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "InteractionInstruction": {
    "Instructions": [
      {
        "Sensor": { "Type": "Not", "Sensor": { "Type": "CanInteract", "ViewSector": 180 } },
        "Actions": [ { "Type": "SetInteractable", "Interactable": false } ]
      },
      {
        "Continue": true,
        "Sensor": { "Type": "Any" },
        "Actions": [ { "Type": "SetInteractable", "Interactable": true, "Hint": "npcs.MMO_Quest_Sands.hint" } ]
      },
      {
        "Sensor": { "Type": "HasInteracted" },
        "Instructions": [
          {
            "Sensor": { "Type": "Not", "Sensor": { "Type": "State", "State": "$Interaction" } },
            "Actions": [
              { "Type": "LockOnInteractionTarget" },
              { "Type": "OpenMmoUi", "Target": "auto" },
              { "Type": "State", "State": "$Interaction" }
            ]
          }
        ]
      }
    ]
  },
  "NameTranslationKey": { "Compute": "NameTranslationKey" }
}
